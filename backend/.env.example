# ============================================
# S-DOORBELL BACKEND - Environment Variables
# ============================================

# Server
NODE_ENV=production
PORT=5000
BASE_URL=https://api.tudominio.com

# Supabase (PostgreSQL) — base de datos de producción
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=tu_service_role_key_secreta

# MongoDB (legacy — solo para el modo dev:local con Mongo en memoria)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sdoorbell?retryWrites=true&w=majority

# JWT
JWT_SECRET=tu_super_secreto_jwt_minimo_32_caracteres_aqui
JWT_EXPIRES_IN=7d

# Frontend URL (visitor web page)
VISITOR_BASE_URL=https://tudominio.com/visit

# Firebase (FCM Push Notifications)
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_PRIVATE_KEY_ID=tu_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=tu_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
